# Copy this file to .env and fill in the values you have.
#   copy .env.example .env      (Windows PowerShell)
#   cp .env.example .env        (macOS / Linux)
#
# .env is gitignored and must never be committed. Every key below is OPTIONAL —
# the pipeline runs fully offline by default and falls back to deterministic
# output when a key is absent.

# --- Available today ---

# Enables LLM-written rationales via:  python scripts/run_pipeline.py --use-llm
# Without it, the pipeline uses the built-in deterministic template rationale.
ANTHROPIC_API_KEY=

# --- Planned enhancements (placeholders; not yet wired into the pipeline) ---

# Data-enrichment provider for fuller founder / company / traction data.
# ENRICHMENT_API_KEY=

# News / signals API for recent-event context on each company.
# NEWS_API_KEY=
